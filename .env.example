# ============================================================
#  CriptoAnalyst — 环境变量配置模板
#  使用方法：cp .env.example .env，然后填入真实 key
#  .env 文件已被 .gitignore 忽略，不会提交到仓库
# ============================================================

# Etherscan API Key（免费注册：https://etherscan.io/myapikey）
# 用于查询 ETH 主网交易记录、事件日志
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Dune Analytics API Key（免费注册：https://dune.com/settings/api）
# 用于执行链上 SQL 查询（黑名单地址查找、桥案例挖掘）
DUNE_API_KEY=your_dune_api_key_here
